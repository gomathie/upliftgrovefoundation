# Supabase — server-side only. Copy this file to .env.local and fill in the
# values from your Supabase project (Settings > API). NEVER commit .env.local.
#
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service role key (secret). This bypasses Row-Level Security and must stay
# server-side only. Do NOT prefix with NEXT_PUBLIC_ and do NOT use it in the
# browser.
SUPABASE_SERVICE_ROLE_KEY=
