# Supabase — server-side only. Copy this file to .env.local and fill in the
# values from your Supabase project (Settings > API keys). NEVER commit .env.local.
#
# No NEXT_PUBLIC_ prefix — these must stay server-side only.

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Secret key (starts with sb_secret_...). This bypasses Row-Level Security and
# must stay server-side only. Do NOT use the publishable key here, and do NOT
# prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# --- Admin panel ---
# Password the admin uses at /admin/login.
ADMIN_PASSWORD=
# Random secret (>=16 chars) that signs the admin session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=

# --- SMTP Mail Settings ---
# Used for sending email notifications (e.g. Resend, SendGrid, Mailgun, or Gmail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@upliftgrovefoundation.org
SMTP_TO_EMAIL=admin@upliftgrovefoundation.org

# Optional: username for the owner/super-admin login (defaults to "admin").
ADMIN_USERNAME=

# --- SMS mNotify Settings ---
# mNotify API Key (from dashboard → API menu)
MNOTIFY_API_KEY=
# Approved Sender ID (max 11 chars)
MNOTIFY_SENDER_ID=UpliftGrv
# Phone number of the counselor/staff to receive new intake alerts
COUNSELOR_PHONE=

