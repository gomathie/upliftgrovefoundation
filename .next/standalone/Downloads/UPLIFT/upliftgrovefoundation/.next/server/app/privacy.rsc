8:["$","$1","c",{"children":[["$","div",null,{"className":"bg-bg-warm-sand min-h-screen py-20","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 bg-white p-10 md:p-16 rounded-2xl shadow-sm border border-gray-100","children":[["$","h1",null,{"className":"text-4xl mb-8","children":"Privacy Policy"}],["$","div",null,{"className":"prose prose-slate max-w-none text-gray-700 space-y-6","children":[["$","p",null,{"children":[["$","strong",null,{"children":"Last Updated:"}]," July 8, 2026"]}],["$","p",null,{"children":"The UpliftGrove Foundation (\"we,\" \"our,\" or \"us\") is committed to protecting your privacy and ensuring the safety and confidentiality of the youth we serve. This Privacy Policy outlines how we collect, use, store, and protect your information when you interact with our website, especially our counseling intake forms."}],["$","h2",null,{"className":"text-2xl text-primary-navy mt-10 mb-4","children":"1. Information We Collect"}],["$","p",null,{"children":"We may collect the following information:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Intake Form Data:"}]," Names (or aliases), locations, phone numbers/WhatsApp numbers, and personal messages submitted through our confidential Get Support form."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Volunteer/Partner Data:"}]," Names, contact information, and professional details submitted through our Get Involved forms."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Donation Data:"}]," Transaction information required to process donations. We do not store full card numbers; these are handled securely by our third-party payment gateway."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Usage Data:"}]," Basic, privacy-respecting analytics to help us understand how our website is used. We do not use invasive tracking scripts on our counseling pages."]}]]}],["$","h2",null,{"className":"text-2xl text-primary-navy mt-10 mb-4","children":"2. How We Use Your Information"}],["$","p",null,{"children":"We use the information we collect for the following purposes:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":"To connect youth in need with our professional counselors."}],["$","li",null,{"children":"To respond to inquiries regarding volunteering, partnerships, or general questions."}],["$","li",null,{"children":"To process and acknowledge donations."}],["$","li",null,{"children":"To improve our services and website experience."}]]}],["$","h2",null,{"className":"text-2xl text-primary-navy mt-10 mb-4","children":"3. Confidentiality and Protection of Youth Data"}],["$","p",null,{"children":"Protecting the privacy of the young people who reach out to us is our highest priority."}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Strict Confidentiality:"}]," Information submitted via the \"Get Support\" intake form is treated with strict confidentiality. It is only accessible to authorized counseling staff."]}],["$","li",null,{"children":[["$","strong",null,{"children":"No Public Sharing:"}]," We will never publicly share your personal information, name, or story without explicit, documented consent from you (and your guardian, if you are a minor)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Secure Storage:"}]," Intake data is stored securely and is not kept in publicly accessible databases."]}]]}],["$","h2",null,{"className":"text-2xl text-primary-navy mt-10 mb-4","children":"4. Sharing Your Information"}],["$","p",null,{"children":"We do not sell, rent, or trade your personal information. We will only share your information in the following circumstances:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":["$Lb","$Lc","$Ld"]}],"$Le","$Lf","$L10"]}]]}]}],null,"$L